# ──────────────────────────────────────────────────────────────────────────
#  PrestaShop connection (BACK OFFICE ONLY)
#  The storefront is 100% decoupled. Plug your PrestaShop instance here later
#  WITHOUT touching a single component.
# ──────────────────────────────────────────────────────────────────────────

# Base URL of the PrestaShop Webservice API (must end with /api)
# Example: https://shop.example.com/api
PRESTASHOP_API_URL=

# PrestaShop Webservice key (Advanced Parameters > Webservice > Add key).
# Sent as HTTP Basic Auth username with an empty password. KEEP IT SECRET.
PRESTASHOP_API_KEY=

# Comma separated list of hostnames serving PrestaShop product images.
# Used by next/image remotePatterns. Example: shop.example.com,cdn.example.com
PRESTASHOP_IMAGE_HOSTS=

# Default language id in PrestaShop (usually 1).
PRESTASHOP_LANG_ID=1

# Default shop id (usually 1). Optional.
PRESTASHOP_SHOP_ID=

# Import produit depuis URL (admin /admin/bbdbuy)
# ID du groupe d'attributs « Taille » dans PrestaShop (optionnel — détection auto).
# PRESTASHOP_SIZE_GROUP_ID=
# PRODUCT_IMPORT_CATEGORY_ID=11
# PRODUCT_IMPORT_PARENT_CATEGORY_ID=2
# PRODUCT_IMPORT_DEFAULT_PRICE=29.99

# Currency ISO code used for formatting prices on the front (display only).
NEXT_PUBLIC_CURRENCY=EUR
NEXT_PUBLIC_LOCALE=fr-FR

# Public site URL (used for SEO / canonical / sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Foot Shop

# IDs catégories PrestaShop (optionnel — sinon détection auto par nom).
# NEXT_PUBLIC_MAILLOTS_CATEGORY_ID=
# NEXT_PUBLIC_SHORTS_CATEGORY_ID=

# Secret used to sign the customer session cookie (HMAC). MUST be set in prod.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ──────────────────────────────────────────────────────────────────────────
#  EMAIL — production Render (recommandé : Resend, API HTTP)
# ──────────────────────────────────────────────────────────────────────────
# Hostinger SMTP ne fonctionne souvent PAS depuis Render (Connection timeout).
# Créez un compte sur https://resend.com, ajoutez le domaine foot-shop.fr,
# copiez la clé API et les enregistrements DNS indiqués par Resend.
#
#   RESEND_API_KEY=re_...
#   MAIL_FROM="Foot Shop <contact@foot-shop.fr>"
#   CONTACT_EMAIL=contact@foot-shop.fr
#   MAIL_REPLY_TO=contact@foot-shop.fr
#
# Test sans domaine vérifié (envoi limité) :
#   MAIL_FROM="Foot Shop <onboarding@resend.dev>"
#
# SMTP Hostinger (local uniquement, ou si Resend indisponible) :
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=587
#   SMTP_SECURE=0
#   SMTP_USER=contact@foot-shop.fr
#   SMTP_PASSWORD=...
#   MAIL_PROVIDER=smtp
#
# Sans RESEND_API_KEY ni SMTP, les emails s'affichent dans la console ([mail:dev]).
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM="Foot Shop <contact@foot-shop.fr>"
CONTACT_EMAIL=contact@foot-shop.fr
MAIL_REPLY_TO=contact@foot-shop.fr
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=contact@foot-shop.fr
SMTP_PASSWORD=
ADMIN_SECRET=

# Email qui reçoit les brouillons BBDBuy (défaut : CONTACT_EMAIL).
SUPPLIER_EMAIL=

# Secret pour le CRON Vercel (peut être identique à ADMIN_SECRET).
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────
#  STRIPE (paiement par carte)
#  1. Créez un compte sur https://dashboard.stripe.com
#  2. Mode test : Developers > API keys > Secret key (sk_test_...)
#  3. Webhook : Developers > Webhooks > Add endpoint
#     URL   : https://VOTRE-DOMAINE.com/api/webhooks/stripe
#     Events: payment_intent.succeeded (+ checkout.session.completed legacy)
#     Copiez le Signing secret (whsec_...)
#  4. Clé publique (côté navigateur) :
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
#  5. Remplissez ci-dessous et redémarrez le serveur.
#  Sans STRIPE_SECRET_KEY, le checkout crée une commande « en attente ».
# ──────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
# id_order_state PrestaShop après paiement réussi (2 = Paiement accepté).
PRESTASHOP_PAID_STATE_ID=2
